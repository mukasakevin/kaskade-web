{
  "name": "kaskade",
  "version": "1.0.0",
  "description": "Kaskade - Monorepo with Next.js frontend and NestJS backend",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "start": "pnpm -r run start",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm -r run test:e2e",
    "format": "pnpm -r run format",
    "backend:dev": "pnpm --filter backend run start:dev",
    "backend:build": "pnpm --filter backend run build",
    "frontend:dev": "pnpm --filter kaskade-frontend run dev",
    "frontend:build": "pnpm --filter kaskade-frontend run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
