### ============================================================
### VARIABLES GLOBALES & CAPTURE AUTO
### ============================================================
@baseUrl = http://localhost:4000/api/v1

# Les variables ci-dessous captent le token du dernier login réussi
@clientToken = {{loginClient.response.body.tokens.accessToken}}
@adminToken = {{loginAdmin.response.body.tokens.accessToken}}
@clientRefreshToken = {{loginClient.response.body.tokens.refreshToken}}

### ------------------------------------------------------------
### 1. REGISTER (Inscription)
### ------------------------------------------------------------
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "obedburindi@gmail.com",
  "password": "password123",
  "fullName": "Obed Burind",
  "phone": "+243999999999",
  "quartier": "Gombe",
  "role": "CLIENT"
}

### ------------------------------------------------------------
### 2. VERIFY OTP (Validation)
### ------------------------------------------------------------
POST {{baseUrl}}/auth/verify-otp
Content-Type: application/json

{
  "email": "obedburindi@gmail.com",
  "otp": "164393"
}

### ------------------------------------------------------------
### 3. RESEND OTP (Renvoyer le code)
### ------------------------------------------------------------
POST {{baseUrl}}/auth/resend-otp
Content-Type: application/json

{
  "email": "obedburindi@gmail.com"
}

### ------------------------------------------------------------
### 4. LOGIN CLIENT (Capture Auto @clientToken)
### ------------------------------------------------------------
# @name loginClient
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "obedburindi@gmail.com",
  "password": "password123"
}

### ------------------------------------------------------------
### 5. LOGIN ADMIN (Capture Auto @adminToken)
### ------------------------------------------------------------
# @name loginAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "kaskade@gmail.com",
  "password": "password123"
}

### ------------------------------------------------------------
### 6. GET ME (Voir mon profil)
### ------------------------------------------------------------
GET {{baseUrl}}/auth/me
Authorization: Bearer {{clientToken}}

### ------------------------------------------------------------
### 7. UPDATE ME (La 10ème route : Modifier mon profil)
### ------------------------------------------------------------
PATCH {{baseUrl}}/auth/me
Authorization: Bearer {{clientToken}}
Content-Type: application/json

{
  "fullName": "Obed Burindi (Modifié)"
}

### ------------------------------------------------------------
### 8. FORGOT PASSWORD (Demander réinitialisation)
### ------------------------------------------------------------
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "obedburindi@gmail.com"
}

### ------------------------------------------------------------
### 9. RESET PASSWORD (Nouveau mot de passe)
### ------------------------------------------------------------
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "bbd3cd616297e60a2ea045cd647f6f85c263cc05c5f774a70de4f8a672d94e6d",
  "newPassword": "Password123"
}

### ------------------------------------------------------------
### 10. REFRESH & LOGOUT
### ------------------------------------------------------------

# @name refreshToken
POST {{baseUrl}}/auth/refresh
Authorization: Bearer {{clientRefreshToken}}

### 
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{clientToken}}
