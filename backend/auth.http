# =========================================================================
# 🛡️ KASKADE - AUTHENTICATION FLOW AUDIT (Brevo + Redis + JWT)
# =========================================================================

@apiV1 = http://localhost:4000/api/v1
@authUrl = {{apiV1}}/auth
@usersUrl = {{apiV1}}/users

# 📝 CONFIGURATION DE TEST (Modifiez une seule fois ici)
@email = kaskade@gmail.com
@password = password123
@fullName = Julian Thorne (Admin)

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 1 : INSCRIPTION (REGISTER)
### -------------------------------------------------------------------------
# @name registerUser
POST {{authUrl}}/register
Content-Type: application/json

{
  "email": "{{email}}",
  "fullName": "{{fullName}}",
  "password": "{{password}}",
  "phone": "0970000000",
  "role": "CLIENT",
  "quartier": "Goma"
}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 2 : TENTER LOGIN SANS VÉRIFICATION (ÉCHEC ATTENDU - 401/403)
### -------------------------------------------------------------------------
# @name loginPending
POST {{authUrl}}/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 3 : RENVOI D'OTP (SI E-MAIL NON REÇU)
### -------------------------------------------------------------------------
# @name resendOtp
POST {{authUrl}}/resend-otp
Content-Type: application/json

{
  "email": "{{email}}"
}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 4 : VÉRIFICATION OTP
### -------------------------------------------------------------------------
# Remplacez manuellement cette valeur après lecture de l'email Brevo
@otpCode = 650822

# @name verifyOtp
POST {{authUrl}}/verify-otp
Content-Type: application/json

{
  "email": "{{email}}",
  "otp": "{{otpCode}}"
}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 5 : CONNEXION (LOGIN APRÈS ACTIVATION)
### -------------------------------------------------------------------------
# @name login
POST {{authUrl}}/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### 📦 EXTRACTION DES TOKENS
@accessToken = {{login.response.body.tokens.accessToken}}
@refreshToken = {{login.response.body.tokens.refreshToken}}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 6 : TEST DE PROTECTION (PROFIL UTILISATEUR)
### -------------------------------------------------------------------------
# @name getProfile
GET {{authUrl}}/me
Authorization: Bearer {{accessToken}}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 7 : TEST DES DROITS (GET ALL USERS - REQUIERT ROLE ADMIN)
### -------------------------------------------------------------------------
GET {{usersUrl}}
Authorization: Bearer {{accessToken}}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 8 : REFRESH DES TOKENS (JWT REFRESH FLOW)
### -------------------------------------------------------------------------
# @name refresh
POST {{authUrl}}/refresh
Content-Type: application/json
Authorization: Bearer {{refreshToken}}

### RÉCUPÉRATION DU NOUVEAU ACCESS TOKEN
@newAccessToken = {{refresh.response.body.tokens.accessToken}}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 9 : DÉCONNEXION (LOGOUT)
### -------------------------------------------------------------------------
# @name logout
POST {{authUrl}}/logout
Authorization: Bearer {{refreshToken}}

### -------------------------------------------------------------------------
### 🛡️ TEST D'ERREUR : MAUVAIS MOT DE PASSE
### -------------------------------------------------------------------------
# @name loginFailed
POST {{authUrl}}/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "WrongPassword123"
}

### -------------------------------------------------------------------------
### 🛡️ TEST D'ERREUR : OTP INVALIDE
### -------------------------------------------------------------------------
# @name verifyOtpFailed
POST {{authUrl}}/verify-otp
Content-Type: application/json

{
  "email": "{{email}}",
  "otp": "000000"
}

### -------------------------------------------------------------------------
### 🛡️ TEST DE RATE LIMITING (BRUTE FORCE PROTECTION)
### -------------------------------------------------------------------------
# Envoyez rapidement plusieurs fois pour tester la limite (429 Too Many Requests)
POST {{authUrl}}/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "WrongPassword123"
}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 10 : MOT DE PASSE OUBLIÉ (FORGOT PASSWORD)
### -------------------------------------------------------------------------
# @name forgotPassword
POST {{authUrl}}/forgot-password
Content-Type: application/json

{
  "email": "{{email}}"
}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 11 : RÉINITIALISATION DU MOT DE PASSE (RESET PASSWORD)
### -------------------------------------------------------------------------
# RÉCUPÉREZ LE TOKEN DEPUIS LES LOGS DU BACKEND OU VOTRE E-MAIL BREVO
@resetToken = 9fd6801fb73b580bfa5065e5d240e3cc21c7d1add8243a9ac0bb8b431a15cbd2
# @name resetPassword
POST {{authUrl}}/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "newPassword": "NewPassword@123!"
}

### -------------------------------------------------------------------------
### 🧪 ÉTAPE 12 : MISE À JOUR DU PROFIL (UPDATE ME)
### -------------------------------------------------------------------------
# @name updateProfile
PATCH {{authUrl}}/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "fullName": "Obed Burindi Updated",
  "phone": "0971111111"
}

### -------------------------------------------------------------------------
### 📊 TABLEAU DE SYNTHÈSE DES TESTS
### -------------------------------------------------------------------------
# 
# ✅ FLUX D'AUTHENTIFICATION COMPLET :
#
# 1. ✅ Inscription (register)
#    POST /auth/register
#    → Crée un utilisateur non vérifié
#    → Envoie un OTP par email via Brevo
#
# 2. ✅ Vérification OTP (verify-otp)
#    POST /auth/verify-otp
#    → Valide le code OTP
#    → Marque l'utilisateur comme vérifié
#    → Supprime l'OTP de Redis
#
# 3. ✅ Connexion (login)
#    POST /auth/login
#    → Génère access token (15 min)
#    → Génère refresh token (7 jours)
#    → Stocke le refresh token en DB
#
# 4. ✅ Profil utilisateur (get profile)
#    GET /auth/me
#    → Requiert access token
#    → Retourne les données de l'utilisateur
#
# 5. ✅ Mise à jour du profil (update profile)
#    PATCH /auth/me
#    → Requiert access token
#    → Modifie fullName, phone, etc.
#
# 6. ✅ Rafraîchissement des tokens (refresh)
#    POST /auth/refresh
#    → Requiert refresh token
#    → Génère un nouveau access token
#
# 7. ✅ Déconnexion (logout)
#    POST /auth/logout
#    → Supprime le refresh token en DB
#    → Invalide la session
#
# 8. ✅ Mot de passe oublié (forgot-password)
#    POST /auth/forgot-password
#    → Génère un token de réinitialisation
#    → Envoie un email avec lien
#
# 9. ✅ Réinitialisation du mot de passe (reset-password)
#    POST /auth/reset-password
#    → Valide le token de réinitialisation
#    → Modifie le mot de passe
#    → Invalide le token
#
# 10. ✅ Renvoi d'OTP (resend-otp)
#     POST /auth/resend-otp
#     → Génère un nouvel OTP
#     → L'envoie par email
#     → Remplace l'ancien OTP dans Redis
#
# 🔐 SÉCURITÉ IMPLÉMENTÉE :
# - Rate limiting : 5 req/15min sur login & register
# - Rate limiting : 3 req/15min sur forgot-password
# - Hachage bcryptjs des mots de passe
# - JWT avec expiration
# - Tokens stockés en Redis (refresh)
# - OTP temporaires (10 min) en Redis
# - Tokens de réinitialisation uniques
# - Protection CORS + HTTPS recommended

### =========================================================================
