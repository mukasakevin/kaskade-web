generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  fullName      String
  phone         String    @unique
  role          Role      @default(CLIENT)
  city          String    @default("Goma")
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  refreshToken  String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  services         Service[]       @relation("ProviderServices")
  clientRequests   Request[]       @relation("ClientRequests")
  providerRequests Request[]       @relation("ProviderRequests")
  adminRequests    Request[]       @relation("AdminRequests")
  reviews          ServiceReview[]
}

model Service {
  id          String    @id @default(uuid())
  title       String
  description String
  category    String
  price       Float
  isActive    Boolean   @default(true)

  providerId  String
  provider    User      @relation("ProviderServices", fields: [providerId], references: [id])

  requests    Request[]
  reviews     ServiceReview[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Request {
  id           String        @id @default(uuid())
  status       RequestStatus @default(PENDING)
  message      String?       // Message initial du client

  // Planning
  scheduledAt  DateTime?     // Date/heure du rendez-vous
  expiresAt    DateTime?     // Expiration automatique de la demande

  // Séquestre
  escrowAmount Float?        // Montant bloqué en séquestre (en $)
  isPaid       Boolean       @default(false)

  // Clés étrangères
  clientId     String
  client       User          @relation("ClientRequests", fields: [clientId], references: [id])

  providerId   String?
  provider     User?         @relation("ProviderRequests", fields: [providerId], references: [id])

  adminId      String?       // Admin qui a approuvé/rejeté
  admin        User?         @relation("AdminRequests", fields: [adminId], references: [id])

  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id])

  review       ServiceReview?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([clientId])
  @@index([providerId])
  @@index([status])
  @@index([expiresAt])
}

model ServiceReview {
  id         String   @id @default(uuid())
  rating     Int      // 1 à 5
  comment    String?

  requestId  String   @unique
  request    Request  @relation(fields: [requestId], references: [id])

  authorId   String
  author     User     @relation(fields: [authorId], references: [id])

  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id])

  createdAt  DateTime @default(now())
}

enum Role {
  CLIENT
  PROVIDER
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  SCHEDULED
  CONFIRMED
  COMPLETED
  REJECTED
  EXPIRED
}
